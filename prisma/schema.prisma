generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Contact {
  id        Int      @id @default(autoincrement())
  name      String
  email     String?
  phone     String   @unique
  address   String?
  gender    String?
  createdAt DateTime @default(now())
}
